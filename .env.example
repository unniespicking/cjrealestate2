# Fill these in later — demo works without them.

# Gemini (Ava chatbot + conversation summarisation)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Slack — preferred path: single Bot Token (enables Claim buttons & thread replies)
SLACK_BOT_TOKEN=                              # xoxb-... (chat:write, chat:write.public, commands)
SLACK_SIGNING_SECRET=                         # to verify incoming interactivity requests

# Slack — legacy path: per-channel incoming webhooks (no interactivity).
# Used as fallback when SLACK_BOT_TOKEN is not set.
SLACK_WEBHOOK_URL=
SLACK_AI_CONVERSATIONS_WEBHOOK_URL=           # #ai_conversation_received
SLACK_CUSTOMER_REQUESTS_WEBHOOK_URL=          # #customer-direct-requests

# Domain.com.au listings
DOMAIN_API_CLIENT_ID=
DOMAIN_API_CLIENT_SECRET=

# CRM
HUBSPOT_API_KEY=
